{
  "name": "incozone",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node prerender.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@studio-freight/lenis": "^1.0.42",
    "firebase": "^12.12.0",
    "lenis": "^1.3.21",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "react-snap": "^1.23.0",
    "sharp": "^0.34.5",
    "vite": "^7.3.1",
    "vite-plugin-image-optimizer": "^2.0.3"
  },
  "reactSnap": {
    "source": "dist",
    "minifyHtml": {
      "collapseWhitespace": false,
      "removeComments": false
    },
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "crawl": false,
    "include": [
      "/",
      "/services",
      "/freezoneincorp",
      "/mainland",
      "/offshore",
      "/banking",
      "/goldenvisa",
      "/visa",
      "/pro",
      "/trademark",
      "/amendments",
      "/liquidation",
      "/specialapprovals",
      "/willregistration",
      "/dmcc",
      "/ifza",
      "/meydan",
      "/rakez",
      "/shams",
      "/jafza",
      "/afz",
      "/adgm",
      "/about",
      "/blog",
      "/contact",
      "/schedule"
    ],
    "skipThirdPartyRequests": true,
    "viewport": {
      "width": 1440,
      "height": 900
    },
    "waitFor": 2000,
    "externalServer": false,
    "saveAs": "html",
    "fixWebpackChunksIssue": false
  }
}
